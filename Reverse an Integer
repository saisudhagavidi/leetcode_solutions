//Reverse an integer
import java.util.Scanner;
class Solution {
    public int reverse(int x) {
        int rev=0;
        while(x!=0){
        int last=x%10;
        rev=rev*10+last;
        x=x/10;
        }
        return rev;
    }
    public static void main(String[] args){
        Scanner s=new Scanner(System.in);
        int x=s.nextInt();
        Solution obj=new Solution();
        int result=obj.reverse(x);
        System.out.print(result);
    }
}
